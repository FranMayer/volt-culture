# =============================================================================
# VOLT Culture — variables de entorno (Vercel + vercel dev + scripts locales)
# Copiá este archivo a .env.local y completá los valores.
# =============================================================================

# --- Firebase Admin (service account) ---
# Usado por APIs serverless, webhooks y scripts en /scripts (checkout, Firestore, auth admin).
FIREBASE_PROJECT_ID=
# Email de la service account (ej. firebase-adminsdk-...@volt-store-65157.iam.gserviceaccount.com)
FIREBASE_CLIENT_EMAIL=
# Clave privada PEM completa; en Vercel pegar con \n literales o saltos de línea reales
FIREBASE_PRIVATE_KEY=

# --- Mercado Pago ---
# Access token de producción o test para Checkout Pro y consultas de pago
MP_ACCESS_TOKEN=
# Secreto del webhook en MP → sin esto no se valida la firma de /api/webhook (recomendado en prod)
MP_WEBHOOK_SECRET=

# --- Resend (emails transaccionales) ---
# API key de Resend; bienvenida, confirmación de compra, cambios de estado de pedido
RESEND_API_KEY=

# --- Sitio público ---
# URL canónica del sitio (back_urls de MP, links en emails). Usar una sola forma: con o sin www
SITE_URL=https://voltculture.com.ar

# --- Cloudinary (panel admin — subida de imágenes de productos) ---
# Dashboard Cloudinary → Product environment credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- WhatsApp admin (CallMeBot, opcional) ---
# Número del admin con código de país, sin + (ej. 5493511234567). Usado en /api/webhook al confirmar venta
ADMIN_WHATSAPP_NUMBER=
# API key de CallMeBot (https://www.callmebot.com/blog/free-api-whatsapp-messages/)
ADMIN_WHATSAPP_APIKEY=

# --- Upstash Redis — rate limiting en /api/* ---
# Crear base en https://console.upstash.com/; si faltan, las APIs siguen sin límite por IP
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Desarrollo / CI (opcional) ---
# Base URL para tests/smoke.test.js (default: https://voltculture.com.ar)
BASE_URL=https://voltculture.com.ar
