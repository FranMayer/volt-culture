rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Productos: lectura pública, escritura solo admin autenticado.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Cupones: get por código exacto es público (preview en checkout), pero
    // list se restringe a admin para que nadie descargue la tabla de códigos.
    match /coupons/{couponId} {
      allow get: if true;
      allow list: if request.auth != null && request.auth.token.admin == true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Pedidos: escritura solo por Admin SDK del backend (allow write: if false bloquea clientes).
    //          Lectura para admin, o para el usuario dueño de la orden (por email).
    match /orders/{orderId} {
      allow read: if request.auth != null &&
        (request.auth.token.admin == true ||
         resource.data.customer.email == request.auth.token.email);
      allow write: if false;
    }

    // Usuarios: cada usuario lee/escribe solo su propio documento.
    //           El admin puede leer todos.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.admin == true;

      // Carrito: solo el propio usuario puede acceder.
      match /cart/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Bloquear cualquier otra colección.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
