rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Imágenes de productos: lectura pública, subida solo admin.
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Archivos legacy en la raíz del bucket (ej. subidas manuales).
    match /{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
